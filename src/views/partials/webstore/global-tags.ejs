<% if(!userSession) { %>
    <script>
        function hideMessage(element) {
            const messageBox = document.getElementById('errorMessage');
            messageBox.classList.remove("Open");
        }

        async function logIn(event) {
            event.preventDefault();

            const form = document.getElementById("logIn");
            const messageBox = document.getElementById('errorMessage');

            try {

                const user = (form[0].value == "") ? null : form[0].value;
                const password = (form[1].value == "") ? null : form[1].value;
                const currentUrl = window.location.pathname + window.location.search;

                if (!user) {

                    messageBox.children[1].innerHTML = `Please, enter a username or email.`;
                    messageBox.classList.add("Open");
                    setTimeout(hideMessage, 5000);

                } else if (!password) {

                    messageBox.children[1].innerHTML = `Please, enter your password.`;
                    messageBox.classList.add("Open");
                    setTimeout(hideMessage, 5000);

                } else {
                    const res = await fetch("/api/auth/login", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ user, password, currentUrl })
                    });

                    const resJson = await res.json();

                    if (resJson.success) {
                        window.location.href = resJson.redirect;
                    } else {
                        messageBox.children[1].innerHTML = resJson.message;
                        messageBox.classList.add("Open");
                        setTimeout(hideMessage, 5000);
                    }
                }
            } catch (error) {
                messageBox.children[1].innerHTML = `Error: ` + error;
                messageBox.classList.add("Open");
                setTimeout(hideMessage, 5000);
            }
        }
    </script>
<% } %>

<script src="https://assets.levount.com/global/js/utils.js"></script>

