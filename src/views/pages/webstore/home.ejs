<script src="https://assets.levount.com/js/home.js" defer></script>
<script>
    async function subscribeNews(event) {
        event.preventDefault();
        const button = document.getElementById("subscribeButton");
        const form = document.getElementById("newsletterSubscription");
        const feedback = document.getElementById("newsletterFeedback");

        try {
            button.disabled = true;
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            const turnstileToken = formData.get("cf-turnstile-response");
            if (!turnstileToken) {
                showError(form, feedback, "Please, wait to the captcha to be released.");
                button.disabled = false;
                return;
            }
            data.token = turnstileToken;

            const res = await fetch('/api/newsletter', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json', 
                    'Accept': 'application/json'
                },
                body: JSON.stringify(data)
            });

            const resJson = await res.json();
            
            if (resJson.success) {
                showSuccess(form, feedback);
                turnstile.reset(); 
            } else {
                showError(form, feedback, resJson.message);
                turnstile.reset();
            }
        } catch (error) {
            showError(form, feedback, error);
        } finally {
            button.disabled = false;
        }
    }

    function showSuccess(form, feedback) {
        form.classList.add('animate-out');
        setTimeout(() => {
            form.style.display = 'none';
            feedback.innerHTML = `
                <div class="feedback-success">
                    <span style="display:block; font-size: 2rem; margin-bottom: 10px;">&#10024;</span> Welcome to the Inner Circle.
                </div>
                `;
            feedback.classList.add('animate-in');
        }, 450);
    }

    function showError(form, feedback, msg) {
        feedback.innerHTML = `<div class="feedback-error">${msg}</div>`;
        feedback.classList.add('animate-in');
        setTimeout(() => {
            feedback.classList.remove('animate-in');
            feedback.style.opacity = '0';
        }, 4000);
    }
</script>