<style>
    body {
        & main {
            display: flex;
            position: relative;
            align-items: flex-start;
            justify-content: center;

            & .gallery {
                flex: 999 1 450px;
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 15px;
                padding: 30px;
                max-width: 500px;

                & .item {
                    & img {
                        width: 100%;
                        height: 100%;
                        object-fit: cover;
                        display: block;
                        border-radius: 2px;
                        transition: all 0.5s;
                        box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px 0px;

                        &:hover {
                            scale: 1.05;
                        }
                    }

                    &.hero-img {
                        grid-column: span 2;
                    }

                    &.extra-img {
                        grid-column: span 1;
                        aspect-ratio: 4/5;

                        &:nth-child(4) {
                            grid-column: span 2;
                        }
                    }
                }
            }

            & hr {
                color: var(--gray-30);
                background-color: var(--gray-30);
                height: 1px;
                border: none;
                width: 80%;
                max-width: 300px;
                margin: 15px 0;
            }

            & .productData {
                flex: 1 1 600px;
                position: sticky;
                top: 70px;
                padding: 30px;
                max-width: 650px;

                & .head {
                    margin: 10px 0;

                    & h3,
                    & h2,
                    & h1 {
                        line-height: 100%;
                        margin: 0;
                        font-weight: 500;
                    }

                    & h1 {
                        font-family: "Playfair Display", serif;
                        font-size: 1.3rem;
                        margin-bottom: 15px;
                        letter-spacing: 1px;
                    }

                    & h2 {
                        color: var(--accent-gold);
                        font-family: "Montserrat", sans-serif;
                    }

                    & h3 {
                        color: var(--gray-50);
                        text-decoration: line-through;
                    }
                }

                & p {
                    font-family: "Nunito Sans", sans-serif;
                    color: var(--gray-60);
                    margin: 0;
                }

                & .purchase {
                    margin: 30px auto;

                    & .buttons {
                        display: flex;
                        gap: 20px;
                        max-width: 400px;
                        margin: auto;

                        & button {
                            height: 40px;
                            transition: all 0.3s;
                            cursor: pointer;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            border: 1px var(--text-dark) solid;
                            font-size: 0.9rem;
                            font-family: "Nunito Sans", sans-serif;
                            text-transform: uppercase;

                            &.addCart {
                                flex-grow: 1;
                                background-color: var(--text-dark);
                                color: var(--font-light);

                                &:hover {
                                    background-color: var(--accent-gold);
                                }
                            }

                            &.fav {
                                aspect-ratio: 1/1;

                                &:hover {
                                    background-color: var(--text-dark);
                                    color: var(--font-light);
                                }
                            }

                            & i {
                                font-family: "LeVountIcons";
                                font-size: 30px;
                                font-style: normal;
                                font-weight: 500;
                                margin-right: 5px;
                            }
                        }
                    }

                    & .labels {
                        margin: 30px;

                        & hr {
                            margin: auto;
                        }

                        & .items {
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            padding: 10px 0;

                            & hr {
                                transform: rotate(90deg);
                                max-width: 50px;
                                margin: 2px;
                                height: 1px;
                                color: var(--gray-70);
                                border: none;
                            }

                            & .label {
                                display: grid;
                                max-width: 80px;
                                color: var(--gray-60);

                                & i {
                                    font-family: "LeVountIcons";
                                    font-size: 30px;
                                    font-style: normal;
                                    font-weight: 300;
                                    text-align: center;
                                    margin-bottom: 4px;
                                }

                                & span {
                                    text-align: center;
                                    line-height: 100%;
                                    font-family: "Nunito Sans", sans-serif;
                                    text-transform: uppercase;
                                    font-size: 0.8rem;
                                }
                            }
                        }
                    }
                }

                & .productDetails {
                    border: 1px var(--gray-30) solid;
                    padding: 15px;
                    width: fit-content;
                    font-size: 0.9rem;

                    & ul {
                        margin: 0;
                        padding: 0;
                        list-style: none;
                        color: var(--gray-70);
                        font-family: "Nunito Sans", sans-serif;

                        & li {
                            line-height: 100%;

                            &+li {
                                margin-top: 5px;
                            }
                        }
                    }
                }
            }
        }
    }

    @media only screen and (max-width: 560px) {

        body {
            & main {
                display: block;

                & .gallery {
                    padding: 0px;
                }

                & .productData {
                    padding: 0;
                    position: unset;
                    margin-top: 20px;

                    & .head {
                        & h1 {
                            font-size: 1rem;
                        }
                    }

                    & p {
                        font-size: 0.9rem;
                        line-height: 110%;
                    }

                    & .productDetails {
                        width: auto;
                    }
                }
            }
        }

    }
</style>

<section class="gallery">

    <% const cleanSku=product?.sku?.trim().replace(/\s+/g, '-' ).toLowerCase(); const category=product?.category; %>

        <div class="item hero-img">
            <img src="/images/products/<%= product?.material %>/<%= category %>/<%= product?.sku %>/<%= cleanSku %>-large.webp"
                alt="<%= product.name %> Main View" onerror="this.src='/images/errors/jewel-placeholder.webp'"
                loading="eager">
        </div>

        <% for (let i=1; i <=4; i++) { %>
            <div class="item extra-img">
                <img src="/images/products/<%= product?.material %>/<%= category %>/<%= product?.sku %>/<%= cleanSku %>-<%= i %>-large.webp"
                    alt="<%= product?.shortProductName %> Detail <%= i %>" onerror="this.closest('.item').remove()"
                    loading="eager">
            </div>
        <% } %>

</section>

<section class="productData">
    <div class="productPath">

    </div>
    <div class="head">
        <h1><%- utils.toTitleCase(product?.shortName) || utils.toTitleCase(product?.name) || "err" %></h1>
        <% if(product?.discountPercentage) { %>
            <h3><%- utils.toCurrency(product?.tagPrice) %></h3>
            <% } %>
                <h2><%- utils.toCurrency(product?.finalUnitPrice) %> USD</h2>
    </div>
    <hr>
    <p><%- utils.capitalize(product?.description) %></p>

    <div class="purchase">
        <div class="buttons">
            <button type="button" class="addCart" onclick="addToCart('<%- product?.sku %>')"><i>&#xe111b;</i>Add to
                cart</button>
            <button type="button" class="fav"><i style="margin-right: 0 !important;">&#xe10f7;</i></button>
        </div>

        <div class="labels">
            <hr>
            <div class="items">
                <% if(product?.discountPrice> 250) { %>
                    <div class="label">
                        <i>&#xe1067;</i>
                        <span>Free shipping</span>
                    </div>
                    <hr>
                    <% } %>
                        <div class="label">
                            <i>&#xe103f;</i>
                            <span>1 year warranty</span>
                        </div>
            </div>
            <hr>
        </div>

        <div class="productDetails">
            <ul>
                <li><b>SKU:</b> <%- product?.sku %></li>
                <li><b>Material:</b> <%- product?.productMaterial %></li>
                <% if (product?.gems) { %>
                    <li><b>Gems:</b> <%- utils.toTitleCase(product?.gems) %></li>
                    <% } %>
                        <% if (product?.stoneColor) { %>
                            <li><b>Stone color:</b> <%- product?.stoneColor %></li>
                            <% } %>
            </ul>
        </div>


    </div>
</section>