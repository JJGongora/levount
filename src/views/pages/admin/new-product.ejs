<style>
    body {
        background-color: #FDFCFB/*var(--gray-10)*/;

        & main {
            padding: 20px;

            & .globalFormContainer {
                max-width: 1200px;
                margin: auto;

                & .mainDetails {
                    display: flex;
                    gap: 20px;
                }

                & .storesDetails {
                    margin-top: 20px;
                    gap: 20px;
                    display: flex;

                    & .store {
                        flex: 999 1 50%;
                    }

                    & h2 {
                        margin: 0;
                        font-family: "Google Sans", sans-serif;
                        font-size: 1rem;
                        margin-bottom: 10px;
                    }
                }

                & .formSection {
                    background-color: var(--lv-white);
                    padding: 15px;
                    border-radius: 5px;
                    border: 1px var(--gray-30) solid;
                    box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px 0px;
                    flex: 999 1 50%;
                    box-sizing: border-box;

                    &.media {
                        flex: 1 1 400px;
                    }
                    
                    & h3 {
                        margin: 0;
                        margin-bottom: 15px;
                    }

                    & .inputContainer {
                        display: grid;
                        row-gap: 4px;
                        flex: 999 1 50%;
                        position: relative;

                        & label {
                            font-size: 0.7rem;
                            font-weight: 600;
                            color: var(--gray-80);
                            text-transform: uppercase;
                            letter-spacing: 1px;
                        }

                        & input, & select, & textarea, & .falseInput {
                            box-sizing: border-box;
                            border: 1px var(--gray-40) solid;
                            border-radius: 5px;
                            min-height: 30px;
                            padding: 3px 5px;
                            font-family: "Google Sans", sans-serif;
                            outline: none;
                            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

                            &.falseInput {
                                padding: 0;
                                display: flex;
                                position: relative;

                                & .invisibleInput {
                                    border: 0;
                                }

                                & .tagsDisplay {
                                    flex-grow: 1;
                                    padding: 3px 5px;
                                    display: flex;
                                    justify-content: end;
                                    flex-wrap: wrap;
                                    gap: 5px;

                                    & .tag {
                                        background-color: var(--lv-gold);
                                        color: var(--lv-white);
                                        display: flex;
                                        gap: 3px;
                                        align-items: center;
                                        padding: 3px 8px;
                                        border-radius: 10px;
                                        font-size: 0.8rem;

                                        & span {
                                            cursor: pointer;
                                            transition: all 0.3s;

                                            &:hover {
                                                color: var(--gray-90);
                                            }
                                        }
                                    }
                                }                                
                            }                            

                            &:focus {
                                border-color: #d4af37;
                                box-shadow: 
                                    inset 0 0 4px rgba(212, 175, 55, 0.2),
                                    0 0 0 2px rgba(212, 175, 55, 0.15), 
                                    0 0 10px rgba(212, 175, 55, 0.3);
                            }
                        }

                        & +.inputContainer {
                            margin-top: 8px;
                        }

                        & .suggestionsList {
                            position: absolute;
                            top: 100%;
                            left: 0;
                            right: 0;
                            background-color: #ffffff;
                            border: 1px solid #ccc;
                            border-top: none;
                            max-height: 150px;
                            overflow-y: auto;
                            margin: 0;
                            padding: 0;
                            list-style: none;
                            z-index: 1000;
                            display: none;
                            box-shadow: 0 4px 6px rgba(0,0,0,0.1);

                            & li {
                                padding: 10px;
                                cursor: pointer;
                                border-bottom: 1px solid #eee;
                                color: #333;

                                &:last-child {
                                    border-bottom: none;
                                }

                                &:hover {
                                    background-color: #f5f5f5;
                                }
                            }

                            
                        }
                    }

                    & .twoInputContainer {
                        display: flex;
                        gap: 15px;

                        & +.twoInputContainer {
                            margin-top: 8px;
                        }

                        & .inputContainer {
                            margin-top: 0 !important;
                        }
                    }
                }
            }
        }
    }
</style>

<form class="globalFormContainer">
    <section class="mainDetails">

        <section class="formSection media">
            <h3>Multimedia</h3>
        </section>

        <section class="formSection">
            <h3>Información general</h3>

            <div class="inputContainer">
                <label for="">Id de sistema</label>
                <input type="text" name="product[id]" readonly>
            </div>

            <div class="twoInputContainer" style="margin-top: 8px;">
                <div class="inputContainer">
                    <label for="">Categoría</label>
                    <select name="product[category]" id="">
                        <option value=""></option>
                        <option value="rings">Anillos</option>
                        <option value="earrings">Aretes</option>
                        <option value="pendants">Dijes</option>
                        <option value="necklace">Collar</option>
                        <option value="bracelets">Brazaletes</option>
                    </select>
                </div>
                <div class="inputContainer">
                    <label for="">Peso (gramos)</label>
                    <input type="number" step="0.01" name="product[weight]" id="">
                </div>                
            </div>

            <div class="twoInputContainer">
                <div class="inputContainer">
                    <label for="">Material</label>
                    <select name="product[material]" id="">
                        <option value="" selected></option>
                        <option value="silver">Plata</option>
                        <option value="gold">Oro</option>
                        <option value="steel">Acero</option>
                    </select>
                </div>
                <div class="inputContainer">
                    <label for="">Pureza</label>
                    <select name="product[purity]" id="">
                        <option value="" selected></option>
                        <option value="14k">14K</option>
                        <option value="18k">18K</option>
                        <option value=".925">.925</option>
                        <option value=".950">.950</option>
                    </select>
                </div>
            </div>

            <div class="twoInputContainer">
                <div class="inputContainer">
                    <label for="">Código LeVount</label>
                    <input type="text" name="product[levountCode]" style="text-transform: uppercase;">
                </div>
                <div class="inputContainer">
                    <label for="">Código alterno</label>
                    <input type="text" name="product[alternateCode]" style="text-transform: uppercase;">
                </div>
            </div>

        </section>        

    </section>

    <section class="storesDetails">        

        <% 
            [
                {
                    id: 0,
                    name: "Le Vount"
                },
                {
                    id: 1,
                    name: "Silver Best Price"
                }
            ]?.forEach(store => {
        %>
        <section class="store">
            <div class="title">
                <h2><%- store?.name %></h2>
            </div>

            <div class="formSection storeSub-Section">                
                <div class="inputContainer">
                    <label for="">Nombre del producto</label>
                    <input type="text" name="product[<%- store?.id %>][name][main]">
                </div>

                <div class="inputContainer">
                    <label for="">Nombre corto</label>
                    <input type="text" name="product[<%- store?.id %>][name][short]">
                </div>

                <div class="inputContainer">
                    <label for="">Precio etiqueta</label>
                    <input type="number" name="product[<%- store?.id %>][tagPrice]">
                </div>

                <div class="twoInputContainer" style="margin: 8px 0;">                    
                    <div class="inputContainer">
                        <label for="">Descuento (%)</label>
                        <input type="number" name="product[<%- store?.id %>][discountPercentage]">
                    </div>
                    <div class="inputContainer">
                        <label for="">Precio con descuento</label>
                        <input type="number" name="product[<%- store?.id %>][discountPrice]" readonly>
                    </div>
                </div>

                <div class="inputContainer">
                    <label for="">Descripción</label>
                    <textarea name="product[<%- store?.id %>][description]"></textarea>
                </div>

                <div class="inputContainer">
                    <label for="">Piedras</label>
                    <div class="falseInput">
                        <input type="text" class="invisibleInput" data-category="gems" placeholder="Escribe para buscar..." oninput="filterSuggestions(this)" onkeydown="handleKeydown(event, this)" autocomplete="off">
                        <div class="tagsDisplay"></div>
                    </div>
                    <ul class="suggestionsList"></ul>
                    <input type="hidden" name="product[<%- store?.id %>][gems]" value="">
                </div>

                <div class="inputContainer">
                    <label for="">Colores</label>
                    <div class="falseInput">
                        <input type="text" class="invisibleInput" data-category="colors" placeholder="Escribe para buscar..." oninput="filterSuggestions(this)" onkeydown="handleKeydown(event, this)" autocomplete="off">
                        <div class="tagsDisplay"></div>
                    </div>
                    <ul class="suggestionsList"></ul>
                    <input type="hidden" name="product[<%- store?.id %>][stoneColors]" value="">
                </div>

                <div class="inputContainer">
                    <label for="">Clasificación</label>
                    <div class="falseInput">
                        <input type="text" class="invisibleInput" data-category="classifications" placeholder="Escribe para buscar..." oninput="filterSuggestions(this)" onkeydown="handleKeydown(event, this)" autocomplete="off">
                        <div class="tagsDisplay"></div>
                    </div>
                    <ul class="suggestionsList"></ul>
                    <input type="hidden" name="product[<%- store?.id %>][classification]" value="">
                </div>

            </div>
        </section>
        <% }); %>

    </section>
</form>

<script>

    document.addEventListener('click', function(event) {
        if (!event.target.closest('.inputContainer')) {
            document.querySelectorAll('.suggestionsList').forEach(ul => {
                ul.style.display = 'none';
            });
        }
    });

    const dbTags = {
        gems: ["Diamante", "Zafiro", "Esmeralda", "Rubí", "Ópalo", "Amatista", "Moissanita"],
        colors: ["Oro 14k", "Oro 18k", "Plata 925", "Platino", "Oro Blanco", "Oro Rosa"]
    };

    function handleKeydown(event, inputElement) {
        if (event.key === 'Enter') {
            event.preventDefault();
            
            const newTag = inputElement.value.trim();
            const container = inputElement.closest('.inputContainer');
            const suggestionsList = container.querySelector('.suggestionsList');
            
            if (newTag !== '') {
                addTag(newTag, suggestionsList);
            }
        }
    }

    function getCurrentTags(container) {
        const hiddenValue = container.querySelector('input[type="hidden"]').value;
        return hiddenValue ? hiddenValue.split(',') : [];
    }

    function updateTags(container) {
        const tagsDisplay = container.querySelector('.tagsDisplay');
        const hiddenInput = container.querySelector('input[type="hidden"]');
        
        let tags = getCurrentTags(container);
        
        tagsDisplay.innerHTML = '';

        tags.forEach((tag, index) => {
            const tagElement = document.createElement('div');
            tagElement.classList.add('tag');
            tagElement.innerHTML = `${tag} <span class="tagDelete" data-index="${index}" onclick="deleteTag(this)">&times;</span>`;
            tagsDisplay.appendChild(tagElement);
        });
    }

    function addTag(newTag, listElement) {
        const container = listElement.closest('.inputContainer');
        const hiddenInput = container.querySelector('input[type="hidden"]');
        const visibleInput = container.querySelector('.invisibleInput');
        
        let tags = getCurrentTags(container);

        if (newTag !== '' && !tags.includes(newTag)) {
            tags.push(newTag);
            hiddenInput.value = tags.join(',');
            updateTags(container);
        }
        
        visibleInput.value = '';
        listElement.style.display = 'none';
        visibleInput.focus();
    }

    function filterSuggestions(inputElement) {
        setTimeout(() => {
            const container = inputElement.closest('.inputContainer');
            const suggestionsList = container.querySelector('.suggestionsList');
            const query = inputElement.value.trim().toLowerCase();
            
            const category = inputElement.getAttribute('data-category');
            
            const categoryTags = dbTags[category] || [];
            
            let currentTags = getCurrentTags(container);

            suggestionsList.innerHTML = '';
            if (query === '') {
                suggestionsList.style.display = 'none';
                return;
            }

            const matchedTags = categoryTags.filter(tag => 
                tag.toLowerCase().includes(query) && !currentTags.includes(tag)
            );

            if (matchedTags.length > 0) {
                matchedTags.forEach(tag => {
                    const li = document.createElement('li');
                    li.textContent = tag;
                    li.addEventListener('click', () => addTag(tag, suggestionsList));
                    suggestionsList.appendChild(li);
                });
                suggestionsList.style.display = 'block';
            } else {
                suggestionsList.style.display = 'none';
            }
        }, 10);
    }

    function deleteTag(deleteButton) {
        const container = deleteButton.closest('.inputContainer');
        const hiddenInput = container.querySelector('input[type="hidden"]');
        const indexToRemove = deleteButton.getAttribute('data-index');
        
        let tags = getCurrentTags(container);
        tags.splice(indexToRemove, 1);
        
        hiddenInput.value = tags.join(',');
        
        updateTags(container);
    }

</script>