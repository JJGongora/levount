<style>
    body {
        background-color: #FDFCFB/*var(--gray-10)*/;

        & main {
            padding: 20px;
            position: relative;

            & .globalFormContainer {
                max-width: 1200px;
                margin: auto;

                & .formSubmitButton {
                    margin-top: 15px;
                    padding: 4px 8px;
                    border-radius: 7px;
                    font-family: "Google Sans", sans-serif;
                    border: 1px var(--gray-40) solid;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    font-size: 0.9rem;
                    transition: all 0.3s ease-in-out;
                    
                    &:hover {
                        background-color: var(--lv-gold);
                        color: var(--lv-white);
                    }
                    & i {
                        font-size: 25px;
                    }
                }

                & .mainDetails {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 20px;
                }

                & .storesDetails {
                    margin-top: 20px;
                    gap: 20px;
                    display: flex;
                    flex-wrap: wrap;

                    & .store {
                        overflow: hidden;
                        flex: 999 1 40%;

                        &.hidden {
                            max-height: 0px;
                            display: none;
                            opacity: 0;
                            visibility: hidden;
                        }
                    }

                    & h2 {
                        margin: 0;
                        font-family: "Google Sans", sans-serif;
                        font-size: 1rem;
                        margin-bottom: 10px;
                    }
                }

                & .formSection {
                    background-color: var(--lv-white);
                    padding: 15px;
                    border-radius: 5px;
                    border: 1px var(--gray-30) solid;
                    box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px 0px;
                    flex: 999 1 50%;
                    box-sizing: border-box;

                    & .note {
                        margin: 0;
                        font-size: 0.7rem;
                        line-height: 90%;
                        color: var(--gray-60);
                        margin-bottom: 10px;
                    }

                    &.media {
                        flex: 1 1 400px;

                        & label {
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                            justify-content: center;
                            padding: 10px;
                            background-color: #f9fafb;
                            border: 2px dashed #cbd5e1;
                            border-radius: 8px;
                            cursor: pointer;
                            transition: all 0.3s ease;
                            text-align: center;

                            &:hover {
                                background-color: #f1f5f9;
                                border-color: #94a3b8;
                            }

                            & i {
                                color: #64748b;
                                font-size: 30px;
                            }

                            .upload-hint {
                                font-size: 0.8rem;
                                color: #94a3b8;
                                margin: 0;
                            }

                            .upload-text {
                                font-size: 0.9rem;
                                color: #334155;
                                font-weight: 500;
                                margin-bottom: 6px;
                                margin: 0;
                            }
                        }

                        & input {
                            display: none;
                        }

                        & .previewContainer {
                            display: flex;
                            gap: 10px;
                            flex-wrap: wrap;
                            margin-top: 15px;

                            & .previewCard {
                                border: 1px solid #ccc;
                                padding: 5px;
                                text-align:center;
                                width: 120px;
                            }

                            & img {
                                width: 100px; height: 100px; object-fit: cover; margin-bottom: 5px;
                            }

                            & div {
                                font-size: 12px; margin-bottom: 5px;
                            }
                        }
                    }
                    
                    & h3 {
                        margin: 0;
                        margin-bottom: 15px;
                    }

                    & .inputContainer {
                        display: grid;
                        row-gap: 4px;
                        flex: 999 1 50%;
                        position: relative;

                        & label {
                            font-size: 0.7rem;
                            font-weight: 600;
                            color: var(--gray-80);
                            text-transform: uppercase;
                            letter-spacing: 1px;
                        }

                        & input, & select, & textarea, & .falseInput {
                            box-sizing: border-box;
                            border: 1px var(--gray-40) solid;
                            border-radius: 5px;
                            min-height: 30px;
                            padding: 3px 5px;
                            font-family: "Google Sans", sans-serif;
                            outline: none;
                            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

                            &.readonly {
                                pointer-events: none;
                                background-color: var(--gray-30);
                            }

                            &.falseInput {
                                padding: 0;
                                display: flex;
                                position: relative;

                                & .invisibleInput {
                                    border: 0;
                                }

                                & .tagsDisplay {
                                    flex-grow: 1;
                                    padding: 3px 5px;
                                    display: flex;
                                    justify-content: end;
                                    flex-wrap: wrap;
                                    gap: 5px;

                                    & .tag {
                                        background-color: var(--lv-gold);
                                        color: var(--lv-white);
                                        display: flex;
                                        gap: 3px;
                                        align-items: center;
                                        padding: 3px 8px;
                                        border-radius: 10px;
                                        font-size: 0.8rem;

                                        & span {
                                            cursor: pointer;
                                            transition: all 0.3s;

                                            &:hover {
                                                color: var(--gray-90);
                                            }
                                        }
                                    }
                                }                                
                            }                            

                            &:focus {
                                border-color: #d4af37;
                                box-shadow: 
                                    inset 0 0 4px rgba(212, 175, 55, 0.2),
                                    0 0 0 2px rgba(212, 175, 55, 0.15), 
                                    0 0 10px rgba(212, 175, 55, 0.3);
                            }
                        }

                        & +.inputContainer {
                            margin-top: 8px;
                        }

                        & .suggestionsList {
                            position: absolute;
                            top: 100%;
                            left: 0;
                            right: 0;
                            background-color: #ffffff;
                            border: 1px solid #ccc;
                            border-top: none;
                            max-height: 150px;
                            overflow-y: auto;
                            margin: 0;
                            padding: 0;
                            list-style: none;
                            z-index: 1000;
                            display: none;
                            box-shadow: 0 4px 6px rgba(0,0,0,0.1);

                            & li {
                                padding: 10px;
                                cursor: pointer;
                                border-bottom: 1px solid #eee;
                                color: #333;

                                &:last-child {
                                    border-bottom: none;
                                }

                                &:hover {
                                    background-color: #f5f5f5;
                                }
                            }

                            
                        }

                        &.checkbox {
                            display: flex;
                            align-items: center;
                            gap: 5px;

                            & input {
                                width: 15px;
                                min-height: 0;
                            }
                        }
                    }

                    & .twoInputContainer {
                        display: flex;
                        gap: 15px;

                        & +.twoInputContainer {
                            margin-top: 8px;
                        }

                        & .inputContainer {
                            margin-top: 0 !important;
                        }
                    }
                }                
            }

            & .backendMessage {
                position: sticky;
                left: 0;
                right: 0;
                top: 10px;
                width: 90%;
                z-index: 2000;
                border-radius: 5px;
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 8px;
                margin: auto;
                visibility: hidden;
                opacity: 0;
                max-height: 0px;
                transition: all 0.3s ease-in-out;

                &.open {
                    max-height: 500px;
                    opacity: 1;
                    visibility: visible;
                }

                & ul {
                    padding: 0;
                    margin: 0;
                    width: 100%;

                    & li {                          
                        background-color: var(--custom-back);
                        color: var(--custom-font); 
                        display: flex;
                        align-items: center;
                        padding: 5px 10px;
                        gap: 8px;
                        border-radius: 5px;

                        & i {
                            font-size: 25px;
                        }

                        &+ li {
                            margin-top: 8px;
                        }
                    }
                }
            }
        }
    }
</style>

<section class="backendMessage" id="backendMessage">
    <ul></ul>
</section>
<form class="globalFormContainer" id="newProductForm" onsubmit="addProduct(event)">
    
    <section class="mainDetails">

        <section class="formSection media">
            <h3>Multimedia</h3>
            <p class="note">Nota: <strong>seleccione las imágenes en orden de relevancia</strong>; la imagen 0 será la usada en la portada del producto.</p>
            <label for="productPhotos">
                <i>&#xe1053;</i>
                <p class="upload-text">Haz clic aquí para seleccionar las imágenes</p>
                <p class="upload-hint">Máximo 5 fotos</p>
            </label>
            <input type="file" name="product[photos]" id="productPhotos" multiple accept="image/*" onchange="changeImages(this)">
            <div class="previewContainer" id="previewContainer">

                <% for(let i=0; i <= 4; i++) { %>
                <div class="previewCard">
                    <img
                        src="https://assets.levount.com/global/images/products/<%- `${product?.material}/${filterHelper.shapeToCategory.english(product?.shape?.toUpperCase()) || product?.variants?.[0]?.category}/${product?.sku?.toLowerCase()}/${product?.sku?.toLowerCase()}${(i > 0) ? `-${i}` : ''}-thumb.webp` %>"
                        onerror="this.parentElement.remove();"
                    >
                    <div>Posición: <%- i %></div>
                    <div>
                        <button type="button">⬅️</button>
                        <button type="button">❌</button>
                        <button type="button">➡️</button>
                    </div>
                </div>
                <% } %>

            </div>
        </section>

        <section class="formSection">
            <h3>Información general</h3>

            <p class="note">
                Nota: los datos ingresados en esta sección serán visibles solo internamente para el personal,
                no para el público que visite las tiendas online.
            </p>

            <div class="twoInputContainer" style="margin-top: 8px;">
                <div class="inputContainer">
                    <label for="">* Forma</label>
                    <select name="product[shape]" id="" required>
                        <option value=""></option>
                        <% shapes?.forEach(shape => { %>
                            <option value="<%- shape?.id %>" <%- (product?.shape?.toUpperCase() == shape?.id) ? 'selected' : '' %>><%- `${shape?.id} - ${utils?.capitalizeFirstLetter(shape?.description)}` %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="inputContainer">
                    <label for="">Peso (gramos)</label>
                    <input type="number" step="0.01" name="product[weight]" id="" value="<%- product?.weight %>">
                </div>                
            </div> 

            <div class="twoInputContainer">
                <div class="inputContainer">
                    <label for="">* Material</label>
                    <select name="product[material]" id="" required>
                        <option value="" <%- (!product?.material) ? 'selected' : ''; %>></option>
                        <option value="silver" <%- (product?.material == 'silver') ? 'selected' : ''; %>>Plata</option>
                        <option value="gold" <%- (product?.material == 'gold') ? 'selected' : ''; %>>Oro</option>
                        <option value="steel" <%- (product?.material == 'steel') ? 'selected' : ''; %>>Acero</option>
                    </select>
                </div>
                <div class="inputContainer">
                    <label for="">Pureza</label>
                    <select name="product[purity]" id="">
                        <option value="" <%- (!product?.purity) ? 'selected' : ''; %>></option>
                        <option value="14k" <%- (product?.purity == '14k') ? 'selected' : ''; %>>14K</option>
                        <option value="18k" <%- (product?.purity == '18k') ? 'selected' : ''; %>>18K</option>
                        <option value=".925" <%- (product?.purity == '.925') ? 'selected' : ''; %>>.925</option>
                        <option value=".950" <%- (product?.purity == '.950') ? 'selected' : ''; %>>.950</option>
                    </select>
                </div>
            </div> 

            <div class="twoInputContainer" style="margin-top: 8px;">                
                <div class="inputContainer">
                    <label for="">Línea</label>
                    <input type="text" name="product[line]">
                </div>
                <div class="inputContainer">
                    <label for="">Familia</label>
                    <input type="text" name="product[family]">
                </div>
            </div>

            <div class="twoInputContainer" style="margin-top: 8px;">
                <div class="inputContainer">
                    <label for="">Precio de etiqueta (USD)</label>
                    <input type="number" name="product[tagPrice]" step="0.01" value="<%- product?.tagPrice %>">
                </div>
                <div class="inputContainer">
                    <label for="">Precio de etiqueta (MXN)</label>
                    <input type="number" name="product[tagPriceMxn]" step="0.01" value="<%- product?.tagPriceMxn %>">
                </div>                
                <div class="inputContainer">
                    <label for="">Costo</label>
                    <input type="number" name="product[cost]" step="0.01" value="<%- product?.cost %>">
                </div>
            </div>            

            <div class="twoInputContainer" style="margin-top: 8px;">
                <div class="inputContainer">
                    <label for="">Código LeVount</label>
                    <input type="text" name="product[levountCode]" style="text-transform: uppercase;" value="<%- product?.levountCode %>">
                </div>
                <div class="inputContainer">
                    <label for="">Código alterno</label>
                    <input type="text" name="product[alternateCode]" style="text-transform: uppercase;" value="<%- product?.alternateCode %>">
                </div>
            </div>   
            
            <div class="inputContainer" style="margin-top: 8px;">
                <label for="">Id de sistema</label>
                <input type="text" class="readonly" name="product[id]" value="<%- product?.id %>" readonly>
            </div>

            <div class="inputContainer">
                <label for="">* SKU (identificador de producto)</label>
                <input type="text" name="product[sku]" value="<%- product?.sku %>" <%- (product?.sku) ? 'readonly class="readonly"' : '' %> required>
            </div>

            <div class="twoInputContainer" style="margin-top: 15px;">
                <div class="inputContainer checkbox">
                    <input type="checkbox" name="product[publish][0]" id="product[publish][levount]" onchange="showStore('levount', this)" <%- (product?.variants?.[0]) ? 'checked' : ''; %>>
                    <label for="product[publish][levount]">Publicar en levount.com</label>
                </div>
                <div class="inputContainer checkbox">
                    <input type="checkbox" name="product[publish][1]" id="product[publish][silverbest]" onchange="showStore('silverbest', this)" <%- (product?.variants?.[1]) ? 'checked' : ''; %>>
                    <label for="product[publish][silverbest]">Publicar en silverbestprice.com</label>
                </div>
            </div>

        </section>        

    </section>

    <section class="storesDetails">        

        <% 
            [
                {
                    id: 0,
                    name: "Le Vount",
                    divName: "levount"
                },
                {
                    id: 1,
                    name: "Silver Best Price",
                    divName: "silverbest"
                }
            ]?.forEach(store => {
        %>
        <section class="store <%- (!product?.variants?.[store?.id]) ? 'hidden' : ''; %>" id="<%- store?.divName %>Store">
            <div class="title">
                <h2><%- store?.name %></h2>
            </div>

            <div class="formSection storeSub-Section">  
                <p class="note">Nota: Los datos de esta sección serán desplegados en la tienda online de <b><%- store?.name %></b> tal cual los ingrese en este formulario.</p>                             

                <div class="inputContainer checkbox">
                    <input type="checkbox" name="product[stores][<%- store?.id %>][outstanding]" <%- (product?.variants?.[store?.id]?.outstanding) ? `checked` : ''; %>>
                    <label for="">Es destacado</label>
                </div>

                <div class="inputContainer">
                    <label for="">Nombre del producto</label>
                    <input type="text" name="product[stores][<%- store?.id %>][name]" value="<%- product?.variants?.[store?.id]?.name %>">
                </div>

                <div class="inputContainer">
                    <label for="">Precio etiqueta</label>
                    <input type="number" name="product[stores][<%- store?.id %>][tagPrice]" id="product[<%- store?.id %>][tagPrice]" onchange="updateDiscount('<%- store?.id %>')"  value="<%- product?.variants?.[store?.id]?.tagPrice %>">
                </div>

                <div class="twoInputContainer" style="margin: 8px 0;">                    
                    <div class="inputContainer">
                        <label for="">Descuento (%)</label>
                        <input type="number" name="product[stores][<%- store?.id %>][discountPercentage]" id="product[<%- store?.id %>][discountPercentage]" onchange="updateDiscount('<%- store?.id %>')" value="<%- product?.variants?.[store?.id]?.discountPercentage %>">
                    </div>
                    <div class="inputContainer">
                        <label for="">Precio con descuento</label>
                        <input type="number" id="product[stores][<%- store?.id %>][discountPrice]" value="<%- product?.variants?.[store?.id]?.discountPrice %>" readonly>
                    </div>
                </div>

                <div class="inputContainer">
                    <label for="">Descripción</label>
                    <textarea name="product[stores][<%- store?.id %>][description]"><%- product?.variants?.[store?.id]?.description %></textarea>
                </div>

                <div class="inputContainer">
                    <label for="">Descripción SEO</label>
                    <textarea name="product[stores][<%- store?.id %>][seoDescription]"><%- product?.variants?.[store?.id]?.seoDescription %></textarea>
                </div>

                <div class="inputContainer">
                    <label for="">Título SEO</label>
                    <input type="text" name="product[stores][<%- store?.id %>][seoTitle]" value="<%- product?.variants?.[store?.id]?.seoTitle %>">
                </div>

                <div class="inputContainer">
                    <label for="">Piedras</label>
                    <div class="falseInput">
                        <input type="text" class="invisibleInput" data-category="gems" placeholder="Escribe para buscar..." oninput="filterSuggestions(this)" onkeydown="handleKeydown(event, this)" autocomplete="off">
                        <div class="tagsDisplay">
                            <% product?.variants?.[store?.id]?.gems?.split(",")?.forEach((gem, index) => { %>    
                                <div class="tag"><%- utils.toTitleCase(gem) %><span class="tagDelete" data-index="<%- index %>" onclick="deleteTag(this)">×</span></div>
                            <% }); %>    
                        </div>
                    </div>
                    <ul class="suggestionsList"></ul>
                    <input type="hidden" name="product[stores][<%- store?.id %>][gems]" value="<%- product?.variants?.[store?.id]?.gems %>">
                </div>

                <div class="inputContainer">
                    <label for="">Colores</label>
                    <div class="falseInput">
                        <input type="text" class="invisibleInput" data-category="colors" placeholder="Escribe para buscar..." oninput="filterSuggestions(this)" onkeydown="handleKeydown(event, this)" autocomplete="off">
                        <div class="tagsDisplay">
                            <% product?.variants?.[store?.id]?.stoneColor?.split(",")?.forEach((color, index) => { %>    
                                <div class="tag"><%- utils.toTitleCase(color) %><span class="tagDelete" data-index="<%- index %>" onclick="deleteTag(this)">×</span></div>
                            <% }); %>     
                        </div>
                    </div>
                    <ul class="suggestionsList"></ul>
                    <input type="hidden" name="product[stores][<%- store?.id %>][stoneColor]" value="<%- product?.variants?.[store?.id]?.stoneColor %>">
                </div>                

                <div class="inputContainer">
                    <label for="">Etiquetas</label>
                    <div class="falseInput">
                        <input type="text" class="invisibleInput" data-category="tags" placeholder="Escribe para buscar..." oninput="filterSuggestions(this)" onkeydown="handleKeydown(event, this)" autocomplete="off">
                        <div class="tagsDisplay">
                            <% product?.variants?.[store?.id]?.tags?.split(",")?.forEach((tag, index) => { %>    
                                <div class="tag"><%- utils.toTitleCase(tag) %><span class="tagDelete" data-index="<%- index %>" onclick="deleteTag(this)">×</span></div>
                            <% }); %>  
                        </div>
                    </div>
                    <ul class="suggestionsList"></ul>
                    <input type="hidden" name="product[stores][<%- store?.id %>][tags]" value="<%- product?.variants?.[store?.id]?.tags %>">
                </div>

                <div class="inputContainer">
                    <label for="">Clasificación</label>
                    <div class="falseInput">
                        <input type="text" class="invisibleInput" data-category="classifications" placeholder="Escribe para buscar..." oninput="filterSuggestions(this)" onkeydown="handleKeydown(event, this)" autocomplete="off">
                        <div class="tagsDisplay">
                            <% product?.variants?.[store?.id]?.classification?.split(",")?.forEach((classification, index) => { %>    
                                <div class="tag"><%- utils.toTitleCase(classification) %><span class="tagDelete" data-index="<%- index %>" onclick="deleteTag(this)">×</span></div>
                            <% }); %> 
                        </div>
                    </div>
                    <ul class="suggestionsList"></ul>
                    <input type="hidden" name="product[stores][<%- store?.id %>][classification]" value="<%- product?.variants?.[store?.id]?.classification %>">
                </div>

                <input type="hidden" name="product[stores][<%- store?.id %>][storeId]" value="<%- store?.id %>">
                <input type="hidden" name="product[stores][<%- store?.id %>][storeName]" value="<%- store?.name %>">

            </div>
        </section>
        <% }); %>

    </section>
    <button type="submit" class="formSubmitButton"><i>&#xe1052;</i><%- (product) ? 'Guardar' : 'Registrar' %></button>
</form>

<script>

    let selectedFiles = [];
    function changeImages(input) {
        const newFiles = Array.from(input.files);
        selectedFiles = [...selectedFiles, ...newFiles];
        input.value="";
        renderizePreview();
    }

    function updateDiscount(storeId) {
        const discountPrice = document.getElementById(`product[${storeId}][discountPrice]`);
        const discountPercentage = document.getElementById(`product[${storeId}][discountPercentage]`);
        const tagPrice = document.getElementById(`product[${storeId}][tagPrice]`);
        discountPrice.value = ((100 - discountPercentage.value) / 100) * tagPrice.value;
    }

    function renderizePreview() {
        const previewContainer = document.getElementById("previewContainer");
        previewContainer.innerHTML = "";

        selectedFiles.forEach((file, index) => {
            const objectURL = URL.createObjectURL(file);

            const div = document.createElement('div');
            div.className = "previewCard";

            div.innerHTML = `
                <img src="${objectURL}">
                <div>Posición: ${index}</div>
                <div>
                    <button type="button" onclick="moveImage(${index}, -1)" ${index === 0 ? 'disabled' : ''}>⬅️</button>
                    <button type="button" onclick="deleteImage(${index})">❌</button>
                    <button type="button" onclick="moveImage(${index}, 1)" ${index === selectedFiles.length - 1 ? 'disabled' : ''}>➡️</button>
                </div>
            `;
            previewContainer.appendChild(div);
        });
    }

    function moveImage(index, direction) {
        const newIndex = index + direction;
        [selectedFiles[index], selectedFiles[newIndex]] = [selectedFiles[newIndex], selectedFiles[index]];
        renderizePreview();
    }

    function deleteImage(index) {
        selectedFiles.splice(index, 1);
        renderizePreview();
    }

    document.addEventListener('click', function(event) {
        if (!event.target.closest('.inputContainer')) {
            document.querySelectorAll('.suggestionsList').forEach(ul => {
                ul.style.display = 'none';
            });
        }
    });

    const dbTags = {
        gems: ["Diamante", "Zafiro", "Esmeralda", "Rubí", "Ópalo", "Amatista", "Moissanita"],
        colors: ["Oro 14k", "Oro 18k", "Plata 925", "Platino", "Oro Blanco", "Oro Rosa"]
    };

    function handleKeydown(event, inputElement) {
        if (event.key === 'Enter') {
            event.preventDefault();
            
            const newTag = inputElement.value.trim();
            const container = inputElement.closest('.inputContainer');
            const suggestionsList = container.querySelector('.suggestionsList');
            
            if (newTag !== '') {
                addTag(newTag, suggestionsList);
            }
        }
    }

    function getCurrentTags(container) {
        const hiddenValue = container.querySelector('input[type="hidden"]').value;
        return hiddenValue ? hiddenValue.split(',') : [];
    }

    function updateTags(container) {
        const tagsDisplay = container.querySelector('.tagsDisplay');
        const hiddenInput = container.querySelector('input[type="hidden"]');
        
        let tags = getCurrentTags(container);
        
        tagsDisplay.innerHTML = '';

        tags.forEach((tag, index) => {
            const tagElement = document.createElement('div');
            tagElement.classList.add('tag');
            tagElement.innerHTML = `${tag} <span class="tagDelete" data-index="${index}" onclick="deleteTag(this)">&times;</span>`;
            tagsDisplay.appendChild(tagElement);
        });
    }

    function addTag(newTag, listElement) {
        const container = listElement.closest('.inputContainer');
        const hiddenInput = container.querySelector('input[type="hidden"]');
        const visibleInput = container.querySelector('.invisibleInput');
        
        let tags = getCurrentTags(container);

        if (newTag !== '' && !tags.includes(newTag)) {
            tags.push(newTag);
            hiddenInput.value = tags.join(',');
            updateTags(container);
        }
        
        visibleInput.value = '';
        listElement.style.display = 'none';
        visibleInput.focus();
    }

    function filterSuggestions(inputElement) {
        setTimeout(() => {
            const container = inputElement.closest('.inputContainer');
            const suggestionsList = container.querySelector('.suggestionsList');
            const query = inputElement.value.trim().toLowerCase();
            
            const category = inputElement.getAttribute('data-category');
            
            const categoryTags = dbTags[category] || [];
            
            let currentTags = getCurrentTags(container);

            suggestionsList.innerHTML = '';
            if (query === '') {
                suggestionsList.style.display = 'none';
                return;
            }

            const matchedTags = categoryTags.filter(tag => 
                tag.toLowerCase().includes(query) && !currentTags.includes(tag)
            );

            if (matchedTags.length > 0) {
                matchedTags.forEach(tag => {
                    const li = document.createElement('li');
                    li.textContent = tag;
                    li.addEventListener('click', () => addTag(tag, suggestionsList));
                    suggestionsList.appendChild(li);
                });
                suggestionsList.style.display = 'block';
            } else {
                suggestionsList.style.display = 'none';
            }
        }, 10);
    }

    function deleteTag(deleteButton) {
        const container = deleteButton.closest('.inputContainer');
        const hiddenInput = container.querySelector('input[type="hidden"]');
        const indexToRemove = deleteButton.getAttribute('data-index');
        
        let tags = getCurrentTags(container);
        tags.splice(indexToRemove, 1);
        
        hiddenInput.value = tags.join(',');
        
        updateTags(container);
    }

    function showBackendResponse(messageDivId, response) {
        const element = document.getElementById(messageDivId);
        const responseContainer = element.children[0]; // El 'ul' que contiene las respuestas.
        let htmlResponse = "";

        if (Array.isArray(response)) {
            response.forEach((item) => {
                const icon = item.status == 'success' ? '&#xe1062;' : ((response.sucess == 'warning') ? '&#xe1063;' : '&#xe1064;');
                const color = item.status == 'success' ? '--custom-back: #c6dfc7; --custom-font: #416b4b;' : ((response.success == 'warning') ? '--custom-back: #ffedb2; --custom-font: #e65100;' : '--custom-back: #E9ADAD; --custom-font: #881414;');

                htmlResponse += `
                        <li style="${color}">
                            <i>${icon}</i>${item.message}
                        </li>
                    `;
            });
        } else {
            const icon = (response.success == true) ? '&#xe1062;' : ((response.sucess == 'warning') ? '&#xe1063;' : '&#xe1064;');
            const color = (response.success == true) ? '--custom-back: #c6dfc7; --custom-font: #416b4b;' : ((response.success == 'warning') ? '--custom-back: #ffedb2; --custom-font: #e65100;' : '--custom-back: #E9ADAD; --custom-font: #881414;');
            htmlResponse += `
                    <li style="${color}">
                        <i>${icon}</i>${response.message}
                    </li>
                `;
        }
        responseContainer.innerHTML = htmlResponse;
        element.classList.toggle("open", true);
    }

    function hideMessage() {
        const element = document.getElementById("backendMessage");
        element.classList.toggle("open", false);
    }

    function showStore(storeDivPrefix, input) {
        const div = document.getElementById(`${storeDivPrefix}Store`);
        console.log(input.checked);
        div.classList.toggle('hidden', (input.checked ? false : true));
    }
</script>

<% if(isProductUpdate) { %>
    <script>
        async function addProduct(event) {
            event.preventDefault();

            try {
                const form = document.getElementById("newProductForm");
                const formData = new FormData(form);
                selectedFiles.forEach((file) => {
                    formData.append('product[photos]', file);
                });
                const res = await fetch(`/api/products/${formData.get('product[material]')}/${formData.get('product[sku]')}`, {
                    method: "PUT",
                    headers: { 'Accept': 'application/json' },
                    body: formData
                });

                const resJson = await res.json();
                if (resJson?.success != false) { 

                    // Si el producto se insertó exitosamente.
                    selectedFiles = [];
                }

                showBackendResponse("backendMessage", resJson);
                setTimeout(hideMessage, 6000);
            } catch (error) {
                console.log(error);
                showBackendResponse("backendMessage", error);
                setTimeout(hideMessage, 6000);
            }
        }
    </script>
