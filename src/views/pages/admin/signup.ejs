<style>
    :root {
        --lv-obsidian: #0f172a;
        --lv-slate: #334155;
        --lv-gold: #c5a059;
        --lv-gold-dim: #b08d4b;
        --lv-white: #ffffff;
        --lv-light: #f8fafc;
        --lv-border: #e2e8f0;
    }

    .user-create-page {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        font-family: 'Inter', sans-serif;
    }

    .header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.8rem;
        color: var(--lv-obsidian);
        margin: 0 0 0.5rem 0;
        font-weight: 700;
    }

    .page-subtitle {
        color: var(--lv-slate);
        margin: 0;
        font-size: 0.9rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .form-card {
        background: white;
        border: 1px solid var(--lv-border);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .card-header {
        background: var(--lv-light);
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--lv-border);
        font-weight: 600;
        color: var(--lv-obsidian);
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
    }

    .card-body {
        padding: 1.5rem;
    }

    /* Inputs */
    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--lv-slate);
        margin-bottom: 0.5rem;
    }

    .form-control {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid var(--lv-border);
        border-radius: 6px;
        font-size: 0.95rem;
        color: var(--lv-obsidian);
        background-color: #fff;
        box-sizing: border-box; /* Vital para que no se salga del contenedor */
        transition: border-color 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--lv-gold);
        box-shadow: 0 0 0 3px rgba(197, 160, 89, 0.1);
    }

    /* Input con botón pegado */
    .input-wrapper {
        display: flex;
    }
    .input-wrapper .form-control {
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
    }
    .btn-addon {
        padding: 0 1rem;
        background: var(--lv-light);
        border: 1px solid var(--lv-border);
        border-left: none;
        border-radius: 0 6px 6px 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Grid interno (Email/Tel) */
    .row-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    /* SELECTOR DE ROLES (Estilo visual) */
    .roles-container {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .role-option {
        display: flex;
        align-items: center;
        padding: 1rem;
        border: 1px solid var(--lv-border);
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s;
    }

    /* Clase que añadiremos con JS para asegurar que se vea seleccionado */
    .role-option.active {
        border-color: var(--lv-gold);
        background-color: #fffbf2; /* Dorado muy claro */
    }

    .role-info {
        flex: 1;
    }
    .role-name {
        display: block;
        font-weight: 600;
        color: var(--lv-obsidian);
    }
    .role-desc {
        display: block;
        font-size: 0.8rem;
        color: var(--lv-slate);
    }
    
    .role-circle {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid #cbd5e1;
        margin-left: 10px;
        position: relative;
    }

    /* Cuando está activo, pintamos el círculo */
    .role-option.active .role-circle {
        border-color: var(--lv-gold);
        background-color: var(--lv-gold);
    }

    /* Ocultamos checkbox real */
    .hidden-check { display: none; }

    /* Botones */
    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 6px;
        border: none;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        font-size: 0.95rem;
        transition: background-color 0.2s;

        &:hover {
            background-color: var(--lv-gold);
            color: var(--lv-white);
        }
    }
    .btn-primary { background: var(--lv-obsidian); color: white; }
    .btn-secondary { background: white; border: 1px solid var(--lv-border); color: var(--lv-slate); }

    /* Responsive */
    @media (max-width: 768px) {
        .form-grid { grid-template-columns: 1fr; }
        .row-2 { grid-template-columns: 1fr; }
    }
</style>

<div class="user-create-page">
    
    <div class="header-flex">
        <div>
            <h1 class="page-title">Registrar Usuario</h1>
            <p class="page-subtitle">Alta de nuevo personal y asignación de permisos.</p>
        </div>
        <div>
            <a href="/admin/users" class="btn btn-secondary">Cancelar</a>
            <button type="submit" form="userForm" class="btn btn-primary">Guardar</button>
        </div>
    </div>

    <form id="userForm" autocomplete="off" onsubmit="event.preventDefault(); signup();">
        <div class="form-grid">
            
            <div class="form-card">
                <div class="card-header">Datos Personales</div>
                <div class="card-body">
                    
                    <div class="form-group">
                        <label class="form-label">Nombre Completo</label>
                        <input type="text" class="form-control" name="fullname" id="fullName" placeholder="Ej. Ana García" required>
                    </div>

                    <div class="row-2">
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="email" placeholder="@levount.com">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Teléfono</label>
                            <input type="tel" class="form-control" name="phone">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Tienda Asignada</label>
                        <select name="storeId" class="form-control" required>
                            <option value="" disabled selected>Seleccione ubicación...</option>
                            <% if (typeof stores !== 'undefined') { %>
                                <% stores.forEach(store => { %>
                                    <option value="<%= store.id %>"><%= store.name %></option>
                                <% }) %>
                            <% } else { %>
                                <option value="1">Tienda Matriz</option>
                            <% } %>
                        </select>
                    </div>

                </div>
            </div>

            <div class="form-card">
                <div class="card-header">Seguridad y Roles</div>
                <div class="card-body">
                    
                    <div class="row-2">
                        <div class="form-group">
                            <label class="form-label">Usuario</label>
                            <div class="input-wrapper">
                                <input type="text" class="form-control" name="username" id="username">
                                <button type="button" class="btn-addon" id="btnGenUser" onclick="generateUser()">⚡</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Contraseña</label>                            
                            <div class="input-wrapper">
                                <input type="password" class="form-control" name="password" required>
                                <button type="button" class="btn-addon" id="btnGenUser" onclick="showPassword()">👁️</button>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Seleccionar Rol</label>
                        <div class="roles-container">
                            
                            <label class="role-option active">
                                <input type="radio" name="role" value="sales" class="hidden-check" checked>
                                <div class="role-info">
                                    <span class="role-name">Vendedor</span>
                                    <span class="role-desc">Acceso a POS y catálogo.</span>
                                </div>
                                <div class="role-circle"></div>
                            </label>

                            <label class="role-option">
                                <input type="radio" name="role" value="admin" class="hidden-check">
                                <div class="role-info">
                                    <span class="role-name">Administrador</span>
                                    <span class="role-desc">Control total de inventario y caja.</span>
                                </div>
                                <div class="role-circle"></div>
                            </label>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </form>
</div>

<script>
    const nameInput = document.getElementById('fullName');
    const userInput = document.getElementById('username');
    const genBtn = document.getElementById('btnGenUser');

    function generateUser() {
        const val = nameInput.value.trim().toLowerCase();
        if(!val) return;
        const parts = val.split(' ');
        const user = parts[0].charAt(0) + '.' + (parts[1] || parts[0]);
        userInput.value = user;
    }

    nameInput.addEventListener('blur', generateUser);
    genBtn.addEventListener('click', generateUser);

    const roleOptions = document.querySelectorAll('.role-option');
    
    roleOptions.forEach(option => {
        option.addEventListener('click', () => {
            roleOptions.forEach(opt => opt.classList.remove('active'));
            option.classList.add('active');
            const radio = option.querySelector('input[type="radio"]');
            if(radio) radio.checked = true;
        });
    });

    async function signup() {
        const form = document.getElementById('userForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch('/auth/signup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify(data)
            });

            const resJson = await response.json();

            if (response.ok) {
                alert(resJson.message || 'Usuario creado con éxito.');
            } else {
                const errorData = await response.json();
                alert('Error: ' + (errorData.message || 'No se pudo crear el usuario.'));
            }
            setTimeout(hideErrorMessage, 5000);
        } catch (error) {
            console.error('Error en la solicitud:', error);
            alert('Error en la solicitud. Intente nuevamente.');
        }
    }

    function hideErrorMessage() {
        const errorDiv = document.getElementById('errorMessage');
        if (errorDiv) {
            errorDiv.style.display = 'none';
        }
    }

    function showPassword() {
        const passwordInput = document.querySelector('input[name="password"]');
        if (passwordInput.type === "password") {
            passwordInput.type = "text";
        } else {
            passwordInput.type = "password";
        }
    }
</script>