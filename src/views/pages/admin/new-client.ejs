    function changeCurrency(element) {
        const currency = element.value;
        const twoInputContainer = element.parentElement.parentElement;
        const exchangeInputs = document.querySelectorAll(`.exchangeCurrency`);
        const amountInput = twoInputContainer.children[3].children[1];
        const methodPay = twoInputContainer.children[1].children[1];
        const index = (element.name.match(/\[payment\]\[(\d+)\]/)) ? element.name.match(/\[payment\]\[(\d+)\]/)[1] : 0;

        if (exchangeInputs.length > 0 && exchangeInputs[index]) {exchangeInputs[index].remove()};
        
        const itemDiv = document.createElement('div');

        if (currency == 'mxn' || currency == 'eur' || currency == 'usd') {

            if(currency != 'mxn') {
                itemDiv.classList = ('inputContainer exchangeCurrency');
                itemDiv.innerHTML = `
                    <label for="">Tipo de cambio</label>
                    <input type="number" step="0.01" name="sale[payment][${index}][exchange]">
                `;
                twoInputContainer.appendChild(itemDiv);
            }
        }
    }

    function deletePayment(element) {
        element.parentElement.remove();
    }

    async function getDocumentData() {
        try {
            const form = document.getElementById("clientData");
            const formData = new FormData(form);

            const documentType = formData.get('documentType') || null;
            const documentNumber = formData.get('documentNumber') || null;
            const storeId = formData.get('storeId') || null;
            const docDate = formData.get('docDate') || null;

            if (documentType && documentNumber && storeId && docDate) {
                const fetchUrl = `/api/documents/${documentType}/${docDate}/${documentNumber}/${storeId}`;
                const res = await fetch(fetchUrl, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    }
                });
                const resJson = await res.json();

                if (resJson.success == true) {

                    if (documentType == 'sale') {
                        const inputsContainerDiv = document.getElementById(`${documentType}Form`);

                        fillContainer(inputsContainerDiv, resJson?.data, 'sale');

                        document.getElementById('itemsContainer').innerHTML = "";
                        resJson?.data?.items?.forEach((item) => {
                            addItem(item);
                        });

                        document.getElementById('payments').innerHTML = "";
                        resJson?.data?.payments?.forEach((payment) => {
                            addPaymentMethod(payment);
                        });
                    }

                    fillContainer(document.getElementById('personalData'), resJson?.data, 'client');
                    const clientPhoneInputId = "client[phone]";
                    const phoneindex = Array.from(telInputs).findIndex(input => input.id === clientPhoneInputId);
                    if (phoneindex !== -1) {
                        itiInstances[phoneindex].setNumber(resJson?.data?.phone);
                    }


                } else {
                    resetFormExcept(form, [
                        'documentType', 'documentNumber', 'storeId', 'docDate', 'docStatus'
                    ]);

                    if (documentType == 'sale') {
                       document.getElementById("itemsContainer").innerHTML = "";
                       document.getElementById("payments").innerHTML = "";
                       productIndex = 0;
                       paymentIndex = 0;
                    } else if (documentType == 'warranty') {
                        document.getElementById("warrantyItems").innerHTML = "";
                        warrantyItemIndex = 0;
                    }
                }

                showResponse("responseMessage", resJson);
                setTimeout(hideMessage, 6000);
            }

        } catch (error) {
            console.error(error);
            showResponse("responseMessage", error);
            setTimeout(hideMessage, 6000);
        }
    }

    function fillContainer(container, data, prefix = '') {
        if (!container || !data) return;

        Object.keys(data).forEach(key => {
            const value = data[key];
            const currentName = prefix ? `${prefix}[${key}]` : key;
            if (typeof value === 'object' && value !== null && !Array.isArray(value)) {
                fillContainer(container, value, currentName);
            }
            const input = container.querySelector(`[name="${currentName}"]`);

            if (input) {
                if (input.type === 'date' && value) {
                    input.value = value.toString().split('T')[0];
                } 
                else if (input.type === 'checkbox' || input.type === 'radio') {
                    if (input.value == value) input.checked = true;
                } 
                else {
                    input.value = (value !== null && value !== undefined) ? value : '';
                }
            }
        });
    }

    

    function resetFormExcept(formElement, fieldsToKeep = []) {
        Array.from(formElement.elements).forEach(input => {
            if (input.name && !fieldsToKeep.includes(input.name) && input.type !== 'submit') {
                if (input.type === 'checkbox' || input.type === 'radio') {
                    input.checked = false;
                } else {
                    input.value = '';
                }
            }
        });
    }

    function showResponse(elementId, response) {
        const element = document.getElementById(elementId);
        const responseContainer = element.children[0];
        let htmlResponse = "";

        if (Array.isArray(response)) {
            response.forEach((item) => {
                const icon = item.status == 'success' ? '&#xe1062;' : ((response.sucess == 'warning') ? '&#xe1063;' : '&#xe1064;');
                const color = item.status == 'success' ? '--custom-back: #c6dfc7; --custom-font: #416b4b;' : ((response.success == 'warning') ? '--custom-back: #ffedb2; --custom-font: #e65100;' : '--custom-back: #E9ADAD; --custom-font: #881414;');

                htmlResponse += `
                        <li style="${color}">
                            <i>${icon}</i>
                            <span>${item.message}</span>
                        </li>
                    `;
            });
        } else {
            const icon = (response.success == true) ? '&#xe1062;' : ((response.sucess == 'warning') ? '&#xe1063;' : '&#xe1064;');
            const color = (response.success == true) ? '--custom-back: #c6dfc7; --custom-font: #416b4b;' : ((response.success == 'warning') ? '--custom-back: #ffedb2; --custom-font: #e65100;' : '--custom-back: #E9ADAD; --custom-font: #881414;');
            htmlResponse += `
                    <li style="${color}">
                        <i>${icon}</i>
                        <span>${response.message}</span>
                    </li>
                `;
        }
        responseContainer.innerHTML = htmlResponse;
        element.classList.toggle("open", true);
    }

    function hideMessage() {
        const element = document.getElementById("responseMessage");
        element.classList.toggle("open", false);
    }

    function switchForm(id) {
        const forms = document.querySelectorAll('.containerDocForm');
        forms.forEach(form => form.classList.toggle('active', false));
        const docForm = document.getElementById(id + "Form");
        docForm.classList.toggle('active', true);

        if (id == 'gift') {
            document.getElementById("personDataContainer").style.display = 'none';
        } else {
            document.getElementById("personDataContainer").style.display = 'block';
        }
    }

    function showExchange(currencyValue) {
        const exchangeContainer = document.getElementById('exchange');
        if (currencyValue === 'mxn') {
            exchangeContainer.querySelector('input').value = '';
            exchangeContainer.style.display = 'none';
        } else {
            exchangeContainer.style.display = 'grid';
        }
    }

    function filterCountry(e) {
        const list = document.getElementById('optionsList');
        const options = list.querySelectorAll('li');

        const searchTerm = e.value.toLowerCase();
        list.classList.remove('hidden');
        options.forEach(option => {
            const itemText = option.innerText.toLowerCase();
            if (itemText.includes(searchTerm)) {
                option.style.display = 'flex';
            } else {
                option.style.display = 'none';
            }
        });
    }

    function showList() {
        const countryinput = document.getElementById('countrySearch');
        const list = document.getElementById('optionsList');
        const options = list.querySelectorAll('li');

        list.classList.remove('hidden');
        options.forEach(op => op.style.display = 'flex');
    }

    function selectCountry(name, flag) {
        const countryinput = document.getElementById('countrySearch');
        const list = document.getElementById('optionsList');
        const options = list.querySelectorAll('li');
        const hiddInput = document.getElementById("telCountryCode");

        countryinput.value = `${name}`;
        hiddInput.value = flag;
        list.classList.add('hidden');
    }

    function addItem(itemData) {
        const itemsContainer = document.getElementById('itemsContainer');

        const itemDiv = document.createElement('div');
        itemDiv.classList.add('itemRow');

        itemDiv.innerHTML = `
            <button type="button" onclick="removeItem(this)"><i>&#xe1118;</i></button>
            <input type="hidden" value="${itemData?.id || ''}" />
            <div class="inputContainer">
                <label>Cantidad</label>
                <input type="number" name="sale[saleItems][${productIndex}][quantity]" min="1" value="${itemData?.quantity || 1}"/>
            </div>
            
            <div class="inputContainer">
                <label>Cód. Le Vount</label>
                <input type="text" name="sale[saleItems][${productIndex}][levCode]" onchange=setUnitPrice(this) value="${itemData?.levountCode || ''}"/>
            </div> 

            <div class="inputContainer">
                <label>Cód. alterno</label>
                <input type="text" name="sale[saleItems][${productIndex}][altCode]" value="${itemData?.alternateCode || ''}"/>
            </div> 

            <div class="inputContainer">
                <label>Material</label>
                <select name="sale[saleItems][${productIndex}][material]">
                    <option value="silver" ${(itemData?.material == 'silver') ? 'selected' : ''}>Plata</option>
                    <option value="gold" ${(itemData?.material == 'gold') ? 'selected' : ''}>Oro</option>
                    <option value="steel" ${(itemData?.material == 'steel') ? 'selected' : ''}>Acero</option>
                </select>
            </div> 
            
            <div class="inputContainer">
                <label>Descripción</label>
                <input type="text" name="sale[saleItems][${productIndex}][description]" value="${itemData?.description || ''}" />
            </div> 

            <div class="inputContainer">
                <label>Precio etiqueta</label>
                <input type="number" name="sale[saleItems][${productIndex}][tagPrice]" step="0.01" value="${itemData?.tagPrice || ''}"/>
            </div> 

            <div class="inputContainer">
                <label>Precio venta</label>
                <input type="number" name="sale[saleItems][${productIndex}][unitPrice]" step="0.01" value="${itemData?.unitPrice || ''}"/>
            </div> 

            <div class="inputContainer">
                <label>Subtotal</label>                
                <input type="number" name="sale[saleItems][${productIndex}][subtotal]" step="0.01" value="${(itemData?.unitPrice * itemData?.quantity) || ''}" readonly />
            </div>     
        `;
        productIndex++;

        itemsContainer.appendChild(itemDiv);
        itemDiv.children[3].children[1].focus();
    }

    function removeItem(button) {
        button.parentElement.remove();
    }


    document.addEventListener('keydown', function(event) {

        if(event.altKey && event.key.toLowerCase() == 'a') {
            if(document.getElementById("documentType").value == 'sale') {
                addItem();
            } else if(document.getElementById("documentType").value == 'gift') {
                addGuest();
            } else if(document.getElementById("documentType").value == 'warranty') {
                addWarrantyItem();
            }
        };

        if(event.altKey && event.key.toLowerCase() == 'c') {
            document.getElementById("clientName").focus();
        };

        if(event.altKey && event.key.toLowerCase() == 'x') {
            if(document.getElementById("documentType").value == 'sale') {
                addPaymentMethod();
            }
        };

    });
</script>