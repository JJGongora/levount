                <input type="email" name="guest[${guestIndex}][email]">
            </div>
            <div class="inputContainer">
                <label>Teléfono</label>
                <input type="tel" class="iti-phone" name="guest[${guestIndex}][phone]">
            </div>
            <div class="inputContainer">
                <label>Habitación</label>
                <input type="number" name="guest[${guestIndex}][room]">
            </div>
            <div class="inputContainer">
                <label>Vendedor</label>
                <input type="text" name="guest[${guestIndex}][seller]">
