    function processItemCode(element) {
        const levountCode = element.value;
        
        const indexMatch = element.name.match(/\[saleItems\]\[(\d+)\]/);
        const index = indexMatch ? indexMatch[1] : 0;

        const match = levountCode.match(/^(.*)([a-zA-Z])(\d+)$/);

        if (match) {
            const itemLeftSection = match[1];
            const unitPrice = match[3];
            const itemShape = match[2];

            const itemProvider = itemLeftSection.charAt(0);
            const itemMaterial = itemLeftSection.charAt(1);
            const itemLine = itemLeftSection.substring(2);
            
            const priceInput = document.getElementsByName(`sale[saleItems][${index}][tagPrice]`)[0];
            if (priceInput) priceInput.value = unitPrice;

            const altCodeInput = document.getElementsByName(`sale[saleItems][${index}][altCode]`)[0];
            if (altCodeInput) altCodeInput.value = itemLine;
        }
    }

    function skipCursorToEnd(element) {
        setTimeout(function() {
