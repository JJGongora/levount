<link rel="stylesheet" href="https://assets.levount.com/flags/css/flag-icons.min.css">
<link rel="stylesheet" href="https://assets.levount.com/global/styles/admin-forms.css">
<link rel="stylesheet" href="https://assets.levount.com/intl-input/build/css/intlTelInput.css">

<section class="Content">
    <h1><%- "Nuevo cliente" //t("pageTitle") %></h1>

    <form onsubmit="registerClient(event)" id="clientData">
        <div class="docData">
            <h3>Datos del documento</h3>

            <div class="containerForm">

                <div class="inputContainer">
                    <label for="">Tipo de documento</label>
                    <select name="documentType" id="documentType" onchange="switchForm(this.value)">
                        <option value="" selected></option>
                        <option value="sale">Nota de venta</option>
                        <option value="warranty">Garantía</option>
                        <option value="gift">Obsequio</option>
                    </select>
                </div>
                <div class="inputContainer">
                    <label for="">Folio</label>
                    <input type="number" min="0" max="9999" name="documentNumber" id="documentNumber" onchange="getDocumentData()">
                </div>
                <div class="inputContainer">
                    <label for="">Sucursal</label>
                    <select name="storeId" id="" onchange="getDocumentData()">
                        <option value="" selected></option>
                        <% for (let n=0; n < branches?.length; n++) { %>
                            <option value="<%- branches?.[n]?.id %>"><%- branches?.[n]?.id + " - " + branches?.[n]?.name
                                    %></option>
                            <% } %>
                    </select>
                </div>
                <div class="inputContainer">
                    <label for="">Fecha de emisión</label>
                    <input type="date" max="<%- utils.dateToInputDate(Today) %>" name="docDate" onchange="getDocumentData()">
                </div>

                <div class="inputContainer">
                    <label for="">Status del documento</label>
                    <select name="docStatus" id="">
                        <option value="active" selected>Activo</option>
                        <option value="cancelled">Cancelado</option>
                    </select>
                </div>

                <button type="button" onclick="getDocumentData()"><i>&#xe110D;</i></button>

            </div>

            <div class="containerDocForm" id="saleForm">
                <h3>Nota de venta</h3>                               

                <section class="saleItems">

                    <h4><button type="button" onclick="addItem()"
                            style="width: fit-content;"><i>&#xe1041</i></button>Artículos vendidos</h4>

                    <div class="itemsContainer" id="itemsContainer">
                        <!-- Items will be added here dynamically -->
                    </div>
                </section>

                <section class="details">
                    <div class="payment" id="paymentDiv">
                        <h4>Forma de pago</h4>
                        
                        <div class="payments" id="payments">
                        </div>

                        <button type="button" onclick="addPaymentMethod()"><i>&#xe1041;</i></button>

                    </div>

                    <div class="container">     
                        <div class="inputContainer">
                            <label for="">Vendedor</label>
                            <input type="text" name="sale[preparedBy]" id="" autocomplete="on">
                        </div>

                        <div class="inputContainer">
                            <label for="">Turno</label>
                            <select name="sale[shift]" id="">
                                <option value="" selected></option>
                                <option value="morning">Mañana</option>
                                <option value="afternoon">Tarde</option>
                            </select>
                        </div>
                    </div> 
                </section>
            </div>

            <div class="containerDocForm" id="giftForm">
                <h3>Dijes de obsequio</h3>

                <section class="guests" id="guests">
                    <div class="guest">
                        <button type="button" onclick="this.parentElement.remove()"><i>&#xe1118;</i></button>
                        <div class="inputContainer">
                            <label>Nombre</label>
                            <input type="text" name="guest[0][name]">
                        </div>
                        <div class="inputContainer">
                            <label>Correo</label>
                            <input type="email" name="guest[0][email]">
                        </div>
                        <div class="inputContainer">
                            <label>Teléfono</label>
                            <input type="tel" class="iti-phone" name="guest[0][phone]">
                        </div>
                        <div class="inputContainer">
                            <label>Habitación</label>
                            <input type="number" name="guest[0][room]">
                        </div>
                        <div class="inputContainer">
                            <label>Vendedor</label>
                            <input type="text" name="guest[0][seller]">
                        </div>
                        <div class="inputContainer">
                            <label>Área</label>
                            <input type="text" name="guest[0][area]">
                        </div>
                    </div>
                </section>

                <button type="button" style="margin-top: 10px;" onclick="addGuest()"><i style="margin-right: 5px;">&#xe1041;</i> Añadir obsequio</button>
            </div>

            <section class="containerDocForm" id="warrantyForm">
                <h3>Garantía</h3>

                <section class="details">
                    <div class="inputContainer">
                        <label>Fecha/hora de entrega</label>
                        <input type="datetime-local" name="warranty[deliverDate]" id="">
                    </div>

                    <div class="inputContainer">
                        <label>Elaborado por</label>
                        <input type="text" name="warranty[seller]" id="">
                    </div>

                    <div class="inputContainer">
                        <label>Fecha de compra</label>
                        <input type="date" name="warranty[purchaseDate]" id="">
                    </div>

                    <div class="inputContainer">
                        <label># Nota</label>
                        <input type="number" name="warranty[purchaseTicket]" id="">
                    </div>

                    <div class="inputContainer">
                        <label>Sucursal de compra</label>
                        <select name="warranty[purchaseBranch]" id="">
                            <option value="" selected></option>
                            <% for (let n=0; n < branches?.length; n++) { %>
                                <option value="<%- branches?.[n]?.id %>"><%- branches?.[n]?.id + " - " + branches?.[n]?.name
                                        %></option>
                                <% } %>
                        </select>
                    </div>

                    <div class="inputContainer">
                        <label>Quien transporta</label>
                        <input type="text" name="warranty[transportist]" id="">
                    </div>

                    <div class="inputContainer">
                        <label>Quien recibe</label>
                        <input type="text" name="warranty[receiver]" id="">
                    </div>
                </section>

                <section class="warrantyItems">
                    <div class="title">
                        <button type="button" onclick="addWarrantyItem()"><i>&#xe1041;</i></button>
                        <h4>Piezas</h4>
                    </div>
                    <div id="warrantyItems"></div>
                </section>
            </section>
        </div>

        <div id="personDataContainer">
            <hr>
            <h2>Datos de contacto</h2>
            <div class="personalData" id="personalData">
                <div class="inputContainer">
                    <label for="">Nombre</label>
                    <input type="text" name="client[name]" id="clientName">
                </div>
                <div class="inputContainer">
                    <label for="">Correo electrónico</label>
                    <input type="email" name="client[email]">
                </div>
                <div class="inputContainer">
                    <label for="">Teléfono</label>
                    <input type="tel" id="client[phone]" name="client[phone]" class="iti-phone">
                </div>
                <div class="inputContainer">
                    <label for="">Habitación</label>
                    <input type="number" name="client[room]">
                </div>
                <div class="custom-select-container">
                    <label for="">País</label>
                    <input type="hidden" name="client[country]" id="telCountryCode">
                    <input type="text" id="countrySearch" autocomplete="off" onclick="showList()"
                        onkeyup="filterCountry(this)">
                    <ul id="optionsList" class="options-list hidden">
                        <% countries.forEach(country=> { %>
                            <li value="<%- country.code %>"
                                onclick="selectCountry('<%- country.name %>', '<%- country.code %>')">
                                <span class="fi fi-<%- country.code?.toLowerCase() %>"></span><%- country.name %>
                            </li>
                            <% }) %>
                    </ul>
                </div>
                <div class="inputContainer">
                    <label for="">Estado/Provincia</label>
                    <input type="text" name="client[state]">
                </div>
                <div class="inputContainer">
                    <label for="">Cumpleaños</label>
                    <input onchange="searchClient(event)" type="date" max="<%- utils.dateToInputDate(Today) %>"
                        name="client[birthday]">
                </div>
                <div class="inputContainer">
                    <label for="">Notas del registro</label>
                    <textarea name="client[remarks]" id=""></textarea>
                </div>
            </div>
        </div>
        <button onclick="registerClient(event)" type="submit"><i>&#xe1052;</i>Guardar</button>
    </form>

    <div class="responseMessage" id="responseMessage">
        <ul>
        </ul>
    </div>
</section>

<script src="https://assets.levount.com/intl-input/build/js/intlTelInput.js"></script>
<script fetchpriority="high">
    let productIndex = 0;
    let paymentIndex = 0;
    let warrantyItemIndex = 0;

    /*const input = document.getElementById("phoneInput");
    const iti = window.intlTelInput(document.getElementById("phoneInput"), {
        initialCountry: "us",
        separateDialCode: false,
        strictMode: true,
        loadUtils: () => import('/intl-input/build/js/utils.js'),
    });*/

    var itiInstances = [];
    const telInputs = document.querySelectorAll(".iti-phone");
    telInputs.forEach(function(input) {
        var instance = window.intlTelInput(input, {
            initialCountry: "us",
            separateDialCode: false,
            strictMode: true,
            loadUtils: () => import('https://assets.levount.com/intl-input/build/js/utils.js'),
        });
        itiInstances.push(instance);
    });
    

    async function registerClient(event) {
        event.preventDefault();

        try {

            let form = document.getElementById("clientData");
            let documentNumber = document.getElementById("documentNumber");
            let clientName = document.getElementById("clientName");
            const formData = new FormData(form);

            let errorFound = false;
            telInputs.forEach((input, index) => {
                const instance = itiInstances[index]; 

                if (instance.isValidNumber()) {
                    formData.set(input.name, instance.getNumber());                    
                    input.classList.remove("error-border"); 
                } else {
                    errorFound = true;
                    //showResponse("responseMessage", `Error en el campo: ${input.name}`);
                    //setTimeout(hideMessage, 6000);
                    input.classList.add("error-border"); 
                }
            });

            /*if (!errorFound) {
                console.log("Datos listos para enviar:", Object.fromEntries(formData));
            } else {
                showResponse("responseMessage", "Por favor corrige los números telefónicos en rojo.");
                setTimeout(hideMessage, 6000);
            }*/

            const data = Object.fromEntries(formData.entries());
            const res = await fetch("/api/clients", {
                method: "POST",
                headers: { "Content-Type": "application/json", 'Accept': 'application/json' },
                body: JSON.stringify(data)
            });

            const resJson = await res.json();

            if (resJson.success == false) {
            } else {
                productIndex = 0;
                paymentIndex = 0;
                guestIndex = 0;
                documentNumber.stepUp();
                clientName.focus();
                document.getElementById('itemsContainer').innerHTML = "";
                document.getElementById('payments').innerHTML = "";
                resetFormExcept(form,
                    [
                        'documentType', 'storeId', 'docDate', 'documentNumber', 'telCountryCode', 'countrySearch',
                        'docStatus', 'sale[preparedBy]', 'sale[shift]'
                    ]
                );
            }
            showResponse("responseMessage", resJson);
            setTimeout(hideMessage, 6000);

        } catch (error) {
            showResponse("responseMessage", error);
            setTimeout(hideMessage, 6000);
        }
    }

