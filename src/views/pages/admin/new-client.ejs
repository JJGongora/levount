                    <option value="ring">A - anillo</option>
                    <option value="earring">B - arete</option>
                    <option value="pendant">C - dije</option>
                    <option value="chain">D - cadena</option>
                    <option value="necklace">E - gargantilla</option>
                    <option value="wristlet">F - pulsera</option>
                    <option value="bracelet">G - brazalete</option>
                    <option value="anklet">H - tobillera</option>
                    <option value="dangly">N - arracada</option>
