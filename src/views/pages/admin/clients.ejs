        try {
            const res = await fetch("/api/whatsapp/stop", {
                method: "POST",
                headers: { "Content-Type": "application/json", 'Accept': 'application/json' },
                body: JSON.stringify({
                })
            })

            const resJson = await res.json();
        } catch (error) {
            console.error(error);
        }
    }

    async function closeSession(event) {
        event.preventDefault();

        try {
            const res = await fetch("/api/whatsapp/close-session", {
                method: "POST",
                headers: { "Content-Type": "application/json", 'Accept': 'application/json' },
                body: JSON.stringify({
                })
            })

            const resJson = await res.json();
        } catch (error) {
            console.error(error);
        }
    }
</script>