        event.preventDefault();

        try {
            const res = await fetch("/api/whatsapp/campaign-sending", {
                method: "POST",
                headers: { "Content-Type": "application/json", 'Accept': 'application/json' },
                body: JSON.stringify({
                })
            })

            const resJson = await res.json();
        } catch (error) {
            console.error(error);
        }
    }

